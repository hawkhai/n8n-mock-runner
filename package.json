{
  "name": "n8n-mock-runner",
  "version": "0.3.0",
  "description": "Standalone n8n node runner — execute n8n community nodes without the n8n runtime. Zero runtime dependency on n8n-workflow.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "tsc --watch",
    "lint": "eslint src tests fixtures",
    "lint:fix": "eslint src tests fixtures --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \"fixtures/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \"fixtures/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "example:sqlite": "ts-node examples/sqlite-demo.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "n8n",
    "n8n-node",
    "n8n-community-node",
    "mock",
    "runner",
    "standalone",
    "testing",
    "workflow"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/n8n-mock-runner.git"
  },
  "homepage": "https://github.com/your-org/n8n-mock-runner#readme",
  "bugs": {
    "url": "https://github.com/your-org/n8n-mock-runner/issues"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/lodash": "^4.17.0",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.4.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "n8n-workflow": ">=0.100.0"
  },
  "peerDependenciesMeta": {
    "n8n-workflow": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
